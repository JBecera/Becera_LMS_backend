#!/usr/bin/env sh

##############################################################################
##
##  Gradle start up script for POSIX generated by Gradle.
##
##  This file contains the following license header:
##  """"
##  SPDX-License-Identifier: Apache-2.0
##
##  Copyright © Gradle contributors
##
##############################################################################

# Attempt to locate a Java runtime.
if [ -n "$JAVA_HOME" ]; then
  JAVA_HOME="$JAVA_HOME"
  export JAVA_HOME
  if [ -d "$JAVA_HOME" ]; then
    :
  fi
else
  if [ -x /usr/bin/java ]; then
    JAVA_HOME="/usr/bin/java"
    export JAVA_HOME
  fi
fi

if [ -z "$JAVA_HOME" ]; then
  echo "ERROR: JAVA_HOME is not set and no 'java' installed."
  exit 1
fi

if [ -d "$JAVA_HOME" ]; then
  JAVA_HOME="$(dirname "$JAVA_HOME")"
  JAVA_HOME="$(dirname "$JAVA_HOME")"
  export JAVA_HOME
fi

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

if [ -n "$APP_HOME" ]; then
  APP_HOME="$(cd "$APP_HOME" && pwd)"
fi

if [ -n "$GRADLE_OPTS" ]; then
  GRADLE_OPTS="$GRADLE_OPTS"
fi

# Determine the Java version.
if [ -n "$JDK_JAVA_OPTIONS" ]; then
  JDK_JAVA_OPTIONS="$JDK_JAVA_OPTIONS"
fi

# Add the Android SDK path for this environment.
if [ -n "$ANDROID_HOME" ]; then
  export ANDROID_HOME="$ANDROID_HOME"
fi

if [ -n "$ANDROID_SDK_ROOT" ]; then
  export ANDROID_SDK_ROOT="$ANDROID_SDK_ROOT"
fi

exec "$JAVA_HOME/bin/java" $JAVA_OPTS $GRADLE_OPTS -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
